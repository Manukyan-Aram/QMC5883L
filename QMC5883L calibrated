#include <Wire.h>

#define QMC_ADDR 0x0D

int16_t x_min = 32767, x_max = -32768;
int16_t y_min = 32767, y_max = -32768;

void setup() {
  Serial.begin(9600);
  Wire.begin();
  
  Wire.beginTransmission(QMC_ADDR);
  Wire.write(0x09); Wire.write(0x1D);
  Wire.endTransmission();
  
  Wire.beginTransmission(QMC_ADDR);
  Wire.write(0x0B); Wire.write(0x01);
  Wire.endTransmission();
  
  Serial.println("Պտտեք սենսորը բոլոր ուղղություններով...");
}

void loop() {
  Wire.beginTransmission(QMC_ADDR);
  Wire.write(0x00);
  Wire.endTransmission(false);
  Wire.requestFrom(QMC_ADDR, 4);

  if (Wire.available() >= 4) {
    int16_t x = (int16_t)(Wire.read() | (Wire.read() << 8));
    int16_t y = (int16_t)(Wire.read() | (Wire.read() << 8));

    if (x < x_min) x_min = x;
    if (x > x_max) x_max = x;
    if (y < y_min) y_min = y;
    if (y > y_max) y_max = y;

    float offsetX = (x_max + x_min) / 2.0;
    float offsetY = (y_max + y_min) / 2.0;

    Serial.print("OffsetX: "); Serial.print(offsetX);
    Serial.print(" | OffsetY: "); Serial.println(offsetY);
  }
  delay(100);
}
