#include <Wire.h>

#define QMC_ADDR 0x0D

// Ձեր տվյալներից ստացված գործակիցները
float offsetX = -845.5; 
float offsetY = 1385.0;  

// Մագնիսական հակում (Երևանի համար մոտ +6.1)
float declination = 6.1; 

void setup() {
  Serial.begin(9600);
  Wire.begin();
  
  // Սենսորի ինիցիալիզացիա
  Wire.beginTransmission(QMC_ADDR);
  Wire.write(0x09); 
  Wire.write(0x1D); 
  Wire.endTransmission();
  
  Wire.beginTransmission(QMC_ADDR);
  Wire.write(0x0B); 
  Wire.write(0x01); 
  Wire.endTransmission();
}

void loop() {
  Wire.beginTransmission(QMC_ADDR);
  Wire.write(0x00);
  Wire.endTransmission(false);
  Wire.requestFrom(QMC_ADDR, 6);

  if (Wire.available() >= 6) {
    int16_t raw_x = (int16_t)(Wire.read() | (Wire.read() << 8));
    int16_t raw_y = (int16_t)(Wire.read() | (Wire.read() << 8));
    int16_t raw_z = (int16_t)(Wire.read() | (Wire.read() << 8));

    // 1. Շեղումների ուղղում (Կալիբրացիա)
    float x = raw_x - offsetX;
    float y = raw_y - offsetY;

    // 2. Անկյան հաշվարկ (ռադիանից աստիճան)
    float heading = atan2(y, x) * 180.0 / PI;
    
    // 3. Աշխարհագրական հյուսիսի ուղղում
    heading += declination;

    // 4. Նորմալացում 0-360° միջակայքում
    if (heading < 0) heading += 360;
    if (heading > 360) heading -= 360;

    Serial.print("Անկյուն: ");
    Serial.print(heading);
    Serial.print("° | ");

    // Կողմնացույցի ուղղությունների ցուցադրում
    if (heading > 337.5 || heading < 22.5) Serial.println("Հյուսիս (N)");
    else if (heading > 22.5 && heading < 67.5) Serial.println("Հյուսիս-Արևելք (NE)");
    else if (heading > 67.5 && heading < 112.5) Serial.println("Արևելք (E)");
    else if (heading > 112.5 && heading < 157.5) Serial.println("Հարավ-Արևելք (SE)");
    else if (heading > 157.5 && heading < 202.5) Serial.println("Հարավ (S)");
    else if (heading > 202.5 && heading < 247.5) Serial.println("Հարավ-Արևմուտք (SW)");
    else if (heading > 247.5 && heading < 292.5) Serial.println("Արևմուտք (W)");
    else if (heading > 292.5 && heading < 337.5) Serial.println("Հյուսիս-Արևմուտք (NW)");
  }
  delay(300);
}
